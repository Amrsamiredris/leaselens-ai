# Copy to .env.local and fill in only what you use.
# LeaseLens runs with NO keys by default (mock AI extraction).
#
# Security: never prefix real API keys with NEXT_PUBLIC_.
# Call providers from a route handler (src/app/api/extract/route.ts) so keys stay server-side.

# OpenAI (future PDF clause extraction)
OPENAI_API_KEY=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# Hugging Face Inference
HF_TOKEN=

# Local model endpoint (e.g. Ollama)
LOCAL_MODEL_URL=http://localhost:11434
